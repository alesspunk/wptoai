{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "index.html",
          "project-area.html",
          "project-area.css",
          "project-area.js",
          "robots.txt",
          "sitemap.xml",
          "images/**",
          "src/models/schema.sql"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}
